{
  "rewrites": [
    { "source": "/mejores-drones-mexico-2026", "destination": "/index.html" },
    { "source": "/mejores-drones-mexico-2026/", "destination": "/index.html" },
    { "source": "/mejores-drones-mexico-2025", "destination": "/index.html" },
    { "source": "/mejores-drones-mexico-2025/", "destination": "/index.html" },
    { "source": "/:path", "destination": "/:path.html" },
    { "source": "/:path/", "destination": "/:path.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
